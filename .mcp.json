{
  "mcpServers": {
    "chrome-devtools-ext": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--categoryExtensions=true",
        "--executablePath=${CHROME_DEVTOOLS_EXECUTABLE:-}"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "axiom": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.axiom.co/mcp"]
    }
  }
}
