{
  "name": "@mr-quin/danmaku-anywhere",
  "version": "1.5.0",
  "private": true,
  "description": "Browser extension for danmaku-anywhere",
  "keywords": [],
  "author": "Mr-Quin",
  "repository": "https://github.com/Mr-Quin/danmaku-anywhere",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "build": "vite build --outDir build --emptyOutDir",
    "build:firefox": "VITE_TARGET_BROWSER=firefox pnpm run build",
    "dev": "vite",
    "dev:browser": "node scripts/open-browser.ts",
    "dev:browser:build": "node scripts/open-browser.ts --build",
    "dev:firefox": "VITE_TARGET_BROWSER=firefox pnpm run dev",
    "dev:harness": "node e2e/harness/serve.mjs",
    "format": "biome format --write",
    "i18n": "i18next-cli",
    "i18n:check": "i18next-cli extract --ci",
    "lint": "tsc && biome check --fix",
    "lint:ci": "biome ci",
    "package": "node ./scripts/package.js",
    "package:firefox": "VITE_TARGET_BROWSER=firefox pnpm run package",
    "postbuild": "node ./scripts/removeViteDir.js",
    "prestandalone:build": "pnpm --filter @danmaku-anywhere/danmaku-provider protobuf:compile",
    "pretest:e2e": "VITE_DA_ENV=e2e pnpm run build",
    "preview": "vite preview",
    "standalone:build": "vite build --config vite.standalone.config.ts --emptyOutDir",
    "standalone:deploy": "wrangler deploy",
    "standalone:dev": "pnpm --filter @danmaku-anywhere/danmaku-provider protobuf:compile && vite --config vite.standalone.config.ts",
    "standalone:serve": "vite preview --config vite.standalone.config.ts",
    "start:firefox": "web-ext run --source-dir ./build --devtools -p ./extention-profile --profile-create-if-missing --keep-profile-changes --pref extensions.dnr.feedback=true",
    "start:firefox-android": "pnpm run start:firefox -t firefox-android --firefox-apk org.mozilla.firefox_beta --pref extensions.dnr.feedback=true",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "tsc": "tsc",
    "type-check": "tsc --noEmit",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.1",
    "@ai-sdk/openai-compatible": "^2.0.1",
    "@danmaku-anywhere/danmaku-converter": "workspace:*",
    "@danmaku-anywhere/danmaku-engine": "workspace:*",
    "@danmaku-anywhere/danmaku-provider": "workspace:*",
    "@danmaku-anywhere/integration-policy": "workspace:*",
    "@danmaku-anywhere/result": "workspace:*",
    "@danmaku-anywhere/web-scraper": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mediapipe/tasks-vision": "0.10.18",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/noto-sans-tc": "^5.2.10",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@mr-quin/dango": "^0.6.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/lab": "9.0.0-beta.3",
    "@mui/material": "^9.0.1",
    "@mui/system": "^9.0.1",
    "@mui/x-data-grid": "^9.3.0",
    "@mui/x-tree-view": "^9.1.0",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.91.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@use-gesture/react": "^10.3.1",
    "ai": "^6.0.3",
    "async-mutex": "^0.5.0",
    "better-auth": "^1.4.18",
    "clarity-js": "^0.8.41",
    "d3": "^7.9.0",
    "dexie": "^4.2.1",
    "i18next": "^25.6.3",
    "immer": "^10.2.0",
    "inversify": "^7.10.4",
    "jszip": "^3.10.1",
    "onnxruntime-web": "^1.26.0",
    "opencc-js": "^1.0.5",
    "pinyin-pro": "^3.27.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.71.1",
    "react-hotkeys-hook": "^5.2.1",
    "react-i18next": "^16.3.5",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.6",
    "reflect-metadata": "^0.2.2",
    "ts-pattern": "^5.9.0",
    "urlpattern-polyfill": "^10.1.0",
    "zod": "^4.3.5",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.2.1",
    "@mr-quin/dango-manifests": "^0.6.0",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.326",
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-react": "^5.1.1",
    "i18next-cli": "^1.28.0",
    "jsdom": "^28.1.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "web-ext": "^9.2.0",
    "wrangler": "^4.50.0"
  }
}
