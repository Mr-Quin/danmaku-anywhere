{
  "name": "@danmaku-anywhere/danmaku-provider",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "author": "Mr-Quin",
  "repository": "https://github.com/Mr-Quin/danmaku-anywhere",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./ddp": "./src/providers/ddp/index.ts",
    "./bilibili": "./src/providers/bilibili/index.ts",
    "./tencent": "./src/providers/tencent/index.ts",
    "./maccms": "./src/providers/macCms/index.ts",
    "./genAi": "./src/providers/genAi/index.ts",
    "./kazumi": "./src/providers/kazumi/index.ts",
    "./config": "./src/providers/config/index.ts",
    "./files": "./src/providers/files/index.ts"
  },
  "scripts": {
    "test": "vitest",
    "protobuf:compile": "pbjs -t static-module -w es6 -o src/protobuf/protobuf.js src/protobuf/definition/bilibili.dm.proto && pbts -o src/protobuf/protobuf.d.ts src/protobuf/protobuf.js",
    "build": "pnpm protobuf:compile",
    "lint": "biome check --fix",
    "lint:ci": "biome ci",
    "type-check": "tsgo --noEmit",
    "openapi-ts": "openapi-ts"
  },
  "dependencies": {
    "@danmaku-anywhere/danmaku-converter": "workspace:*",
    "@danmaku-anywhere/result": "workspace:*",
    "protobufjs": "^7.5.4",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.88.0",
    "copyfiles": "^2.4.1",
    "protobufjs-cli": "^1.1.3",
    "vitest": "^4.0.13"
  }
}
