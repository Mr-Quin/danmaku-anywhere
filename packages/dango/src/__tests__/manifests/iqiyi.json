{
  "apiVersion": 1,
  "id": "iqiyi",
  "name": "iQiyi",
  "version": "0.1.0",
  "hosts": ["mesh.if.iqiyi.com"],
  "search": {
    "inputs": ["q"],
    "steps": [
      {
        "type": "assign",
        "id": "base",
        "values": {
          "params": "{ 'key': q, 'pageNum': '1', 'pageSize': '25', 'mode': '1' }"
        }
      },
      {
        "type": "assign",
        "id": "signed",
        "values": {
          "params": "$merge([base.params, { 'sign': $uppercase($md5($sortedRawString(base.params) & '&secret_key=howcuteitis')) }])"
        }
      },
      {
        "type": "http",
        "id": "search",
        "request": {
          "method": "GET",
          "url": "'https://mesh.if.iqiyi.com/portal/lw/search/homePageV3'",
          "query": "signed.params"
        }
      }
    ],
    "output": "[search.data.templates[albumInfo].albumInfo.{ 'providerIds': { 'qipuId': $string(qipuId) }, 'title': title, 'year': year }]"
  }
}
