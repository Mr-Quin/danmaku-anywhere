{
  "apiVersion": 1,
  "id": "bilibili",
  "name": "Bilibili",
  "version": "0.1.0",
  "hosts": ["api.bilibili.com"],
  "search": {
    "inputs": ["q"],
    "steps": [
      {
        "type": "http",
        "id": "nav",
        "request": {
          "method": "GET",
          "url": "'https://api.bilibili.com/x/web-interface/nav'"
        },
        "extract": {
          "imgKey": "$regexExtract(data.wbi_img.img_url, '/([a-f0-9]+)\\\\.png')",
          "subKey": "$regexExtract(data.wbi_img.sub_url, '/([a-f0-9]+)\\\\.png')"
        }
      },
      {
        "type": "assign",
        "id": "wbiTable",
        "values": {
          "indices": "[46, 47, 18, 2, 53, 8, 23, 32, 15, 50, 10, 31, 58, 3, 45, 35, 27, 43, 5, 49, 33, 9, 42, 19, 29, 28, 14, 39, 12, 38, 41, 13, 37, 48, 7, 16, 24, 55, 40, 61, 26, 17, 0, 1, 60, 51, 30, 4, 22, 25, 54, 21, 56, 59, 6, 63, 57, 62, 11, 36, 20, 34, 44, 52]"
        }
      },
      {
        "type": "assign",
        "id": "wbi",
        "values": {
          "mixinKey": "$substring($permute(wbiTable.indices, nav.imgKey & nav.subKey), 0, 32)",
          "wts": "$string($now())"
        }
      },
      {
        "type": "assign",
        "id": "base",
        "values": {
          "params": "{ 'keyword': q, 'search_type': 'media_bangumi', 'wts': wbi.wts }"
        }
      },
      {
        "type": "assign",
        "id": "signed",
        "values": {
          "params": "$merge([base.params, { 'w_rid': $md5($sortedQueryString(base.params) & wbi.mixinKey) }])"
        }
      },
      {
        "type": "http",
        "id": "search",
        "request": {
          "method": "GET",
          "url": "'https://api.bilibili.com/x/web-interface/wbi/search/type'",
          "query": "signed.params",
          "headers": {
            "Referer": "'https://www.bilibili.com/'"
          }
        }
      }
    ],
    "output": "[search.data.result.{ 'providerIds': { 'seasonId': $string(season_id), 'mediaId': $string(media_id) }, 'title': $replace(title, /<[^>]+>/, ''), 'type': season_type_name, 'episodeCount': ep_size }]"
  }
}
