{
  "apiVersion": 1,
  "id": "bilibili",
  "name": "Bilibili",
  "version": "0.1.0",
  "hosts": ["api.bilibili.com", "comment.bilibili.com"],
  "search": {
    "inputs": ["q"],
    "steps": [
      {
        "type": "http",
        "id": "media_bangumi",
        "request": {
          "method": "GET",
          "url": "'https://api.bilibili.com/x/web-interface/search/type'",
          "query": "{ 'keyword': q, 'search_type': 'media_bangumi' }",
          "credentials": "include",
          "headers": { "Referer": "'https://www.bilibili.com/'" }
        }
      },
      {
        "type": "http",
        "id": "media_ft",
        "request": {
          "method": "GET",
          "url": "'https://api.bilibili.com/x/web-interface/search/type'",
          "query": "{ 'keyword': q, 'search_type': 'media_ft' }",
          "credentials": "include",
          "headers": { "Referer": "'https://www.bilibili.com/'" }
        }
      }
    ],
    "output": "[[media_bangumi.data.result, media_ft.data.result].{ 'providerIds': { 'seasonId': $string(season_id), 'mediaId': $string(media_id) }, 'title': $replace(title, /<[^>]+>/, ''), 'type': season_type_name, 'episodeCount': ep_size }]"
  }
}
