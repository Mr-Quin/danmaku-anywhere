{
  "apiVersion": 1,
  "id": "builtin:ddp-compat",
  "name": "DanDanPlay Compatible",
  "version": "1.0.0",
  "hosts": ["*"],
  "configSchema": {
    "baseUrl": {
      "type": "string",
      "label": "Base URL",
      "description": "Root of the DanDanPlay-compatible API (e.g. https://my-server.com)"
    }
  },
  "search": {
    "inputs": ["q", "baseUrl", "authHeaders"],
    "steps": [
      {
        "type": "http",
        "id": "search",
        "request": {
          "method": "GET",
          "url": "$replace(baseUrl, /\\/$/, '') & '/v2/search/anime'",
          "query": "{ 'keyword': q }",
          "headers": "$merge(authHeaders.{ key: value })"
        }
      }
    ],
    "output": "[search.animes.{ 'providerIds': { 'animeId': animeId, 'bangumiId': bangumiId }, 'indexedId': $string(animeId), 'title': animeTitle, 'type': type, 'typeDescription': typeDescription, 'imageUrl': imageUrl, 'episodeCount': episodeCount, 'year': $number($substringBefore(startDate, '-')) }]"
  },
  "episodes": {
    "inputs": ["bangumiId", "baseUrl", "authHeaders"],
    "steps": [
      {
        "type": "http",
        "id": "bangumi",
        "request": {
          "method": "GET",
          "url": "$replace(baseUrl, /\\/$/, '') & '/v2/bangumi/' & $string(bangumiId)",
          "headers": "$merge(authHeaders.{ key: value })"
        }
      }
    ],
    "output": "[bangumi.bangumi.episodes.{ 'providerIds': { 'episodeId': episodeId, 'animeId': %.animeId, 'bangumiId': %.bangumiId }, 'indexedId': $string(episodeId), 'title': episodeTitle, 'episodeNumber': episodeNumber }]"
  },
  "danmaku": {
    "inputs": ["episodeId", "baseUrl", "authHeaders"],
    "steps": [
      {
        "type": "http",
        "id": "comments",
        "request": {
          "method": "GET",
          "url": "$replace(baseUrl, /\\/$/, '') & '/v2/comment/' & $string(episodeId)",
          "query": "{ 'withRelated': 'true' }",
          "headers": "$merge(authHeaders.{ key: value })"
        }
      }
    ],
    "output": "[comments.comments]"
  }
}
